{
  "openapi": "3.0.0",
  "info": {
    "title": "Contacts Analysis API",
    "description": "Filter, search, summarise and validate a 15K-row contacts dataset via natural language queries",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://hiteshsathvick.onrender.com"
    }
  ],
  "paths": {
    "/query": {
      "post": {
        "summary": "Handle Query",
        "description": "Send a natural language query about the contacts dataset. Examples: show dataset summary, top job titles, top companies, search for engineer, show invalid contacts.",
        "operationId": "handleQuery",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reload": {
      "post": {
        "summary": "Reload Dataset",
        "description": "Re-read the source Excel file and rebuild the in-memory parquet cache.",
        "operationId": "reloadDataset",
        "responses": {
          "200": {
            "description": "Reload completed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QueryRequest": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": {
            "type": "string",
            "description": "Natural language query about the contacts dataset"
          }
        }
      },
      "QueryResponse": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "The original query"
          },
          "result": {
            "type": "string",
            "description": "The analysis result"
          }
        }
      }
    }
  }
}
